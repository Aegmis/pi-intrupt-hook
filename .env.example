# Required
AEGMIS_BASE_URL=https://api.aegmis.com
AEGMIS_API_KEY=sk_org_xxxx_yyyy

# Master kill switch — set false to disable the approval gate entirely (allow all)
AEGMIS_APPROVAL=true

# Optional tuning
AEGMIS_FORWARD_ALL=true
AEGMIS_TIMEOUT=600
AEGMIS_POLL_INTERVAL=5

# Where approval requests are delivered: slack (default) or email
AEGMIS_CHANNEL=slack

# Bypass approval for specific shell commands (comma-separated regex)
# AEGMIS_BYPASS_PATTERNS=^git\s+status$,^ls\b

# Extra dirs to also gate `rm` on (comma-separated; dir + everything under it),
# on top of the built-in home/root/system catastrophes.
AEGMIS_PROTECTED_PATHS=re:^$HOME$
# List one or MANY, comma-separated (each = the dir + everything under it;
# relative rm targets are resolved against the command's cwd). For example:
#   AEGMIS_PROTECTED_PATHS=$HOME/work,$HOME/secrets,$HOME/project
# Prefix an entry with re: for a regex (matched vs the resolved absolute path);
# anchor with ^...$ to match a dir exactly (not its contents). For example:
#   AEGMIS_PROTECTED_PATHS=re:^$HOME$,re:^$HOME/(work|important)(/|$)

# HARD DENY (no approval round-trip): rm targets matching these are blocked
# LOCALLY and never sent for approval. Same syntax as AEGMIS_PROTECTED_PATHS
# (literal dir + subtree, or re: regex). Local mode only (AEGMIS_FORWARD_ALL=false).
# Example: deny deleting the home dir itself outright.
#   AEGMIS_BLOCKED_PATHS=re:^$HOME$
